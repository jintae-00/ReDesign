# ReDesign configuration — copy to `.env` and fill in your own values.

# --- VLM controller (OpenAI-compatible chat-completions endpoint) ---
OPENAI_API_KEY=
# Custom OpenAI-compatible endpoint (a gateway, proxy, or self-hosted vLLM).
# Leave empty to use the default OpenAI API (https://api.openai.com/v1).
OPENAI_BASE_URL=
# Which chat model the controller calls (default: gemini-3-flash-preview).
VLM_MODEL=

# --- Optional: Gemini key for the nanobanana tool ---
GEMINI_API_KEY=
